# Supabase session pooler (IPv4-proxied — get host/region from Project Settings > Database)
DB_USER=postgres.<project-ref>
DB_PASSWORD=
DB_HOST=aws-0-<region>.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres

API_VERSION=0.0.1
API_PREFIX=/api

DOCKER_PROJECT_NAME=financial_api
DOCKER_VOLUME_DOCKER=./docker
DOCKER_PORT=8000
